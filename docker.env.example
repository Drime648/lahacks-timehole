MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/timehole?retryWrites=true&w=majority
MONGODB_DB_NAME=timehole
SESSION_SECRET=change-me
WEB_PORT=3000
GATEWAY_PROXY_PORT=8080
DNS_PORT=5354

# Optional explicit external proxy address for the Web Proxy page.
# If unset, the web app falls back to the current browser host and this proxy port.
GATEWAY_PROXY_HOST=
GATEWAY_PROXY_BASE_URL=

PROXY_ENABLE_HTTPS_MITM=true
PROXY_ENABLE_GEMMA_CLASSIFIER=true
GEMINI_API_KEY=
GEMMA_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMMA_MODEL=gemma-3-27b-it
GEMMA_TIMEOUT_SECONDS=3
GEMMA_TEMPERATURE=0
GEMMA_TOP_P=0
GEMMA_TOP_K=1
GEMMA_RATE_LIMIT_CALLS=20
GEMMA_RATE_LIMIT_WINDOW_SECONDS=60
CLASSIFIER_CACHE_VERSION=remote-gemma-v2-lenient-platforms
